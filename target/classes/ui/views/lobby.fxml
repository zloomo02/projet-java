<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.LobbyController" styleClass="screen-root">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label fx:id="welcomeLabel" styleClass="title"/>
    <Label text="Salles disponibles" styleClass="subtitle"/>

    <TableView fx:id="roomsTable" prefHeight="250">
        <columns>
            <TableColumn fx:id="roomNameColumn" text="Salle" prefWidth="220"/>
            <TableColumn fx:id="playersColumn" text="Joueurs" prefWidth="120"/>
            <TableColumn fx:id="maxColumn" text="Max" prefWidth="120"/>
        </columns>
    </TableView>

    <HBox spacing="10">
        <TextField fx:id="roomNameField" promptText="Nom de la nouvelle salle" HBox.hgrow="ALWAYS"/>
        <TextField fx:id="maxPlayersField" promptText="4" prefWidth="80"/>
        <Button text="Creer" onAction="#onCreateRoomClicked" styleClass="primary-btn"/>
        <Button text="Rejoindre" onAction="#onJoinRoomClicked" styleClass="secondary-btn"/>
        <Button text="Pret" onAction="#onReadyClicked" styleClass="accent-btn"/>
    </HBox>

    <Label fx:id="statusLabel" text="" styleClass="status-label" wrapText="true"/>
</VBox>
