<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.GameController" styleClass="screen-root">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <center>
        <VBox spacing="12">
            <Label text="Question en cours" styleClass="subtitle"/>
            <Label fx:id="questionLabel" text="En attente de la premiere question..." wrapText="true" styleClass="question-label"/>
            <ProgressBar fx:id="timerProgress" progress="1.0" prefWidth="500"/>

            <GridPane hgap="10" vgap="10">
                <Button fx:id="optionAButton" text="A" onAction="#onAnswerAClicked" GridPane.columnIndex="0" GridPane.rowIndex="0" maxWidth="1.7976931348623157E308" styleClass="answer-btn"/>
                <Button fx:id="optionBButton" text="B" onAction="#onAnswerBClicked" GridPane.columnIndex="1" GridPane.rowIndex="0" maxWidth="1.7976931348623157E308" styleClass="answer-btn"/>
                <Button fx:id="optionCButton" text="C" onAction="#onAnswerCClicked" GridPane.columnIndex="0" GridPane.rowIndex="1" maxWidth="1.7976931348623157E308" styleClass="answer-btn"/>
                <Button fx:id="optionDButton" text="D" onAction="#onAnswerDClicked" GridPane.columnIndex="1" GridPane.rowIndex="1" maxWidth="1.7976931348623157E308" styleClass="answer-btn"/>
            </GridPane>

            <Label fx:id="feedbackLabel" text="" styleClass="status-label"/>
        </VBox>
    </center>

    <right>
        <VBox spacing="8" prefWidth="260">
            <Label text="Scores en direct" styleClass="subtitle"/>
            <TableView fx:id="scoresTable" prefHeight="350">
                <columns>
                    <TableColumn fx:id="usernameColumn" text="Joueur" prefWidth="150"/>
                    <TableColumn fx:id="scoreColumn" text="Score" prefWidth="90"/>
                </columns>
            </TableView>
        </VBox>
    </right>
</BorderPane>
