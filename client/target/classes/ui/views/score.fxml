<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12.0" alignment="CENTER" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.ScoreController" styleClass="screen-root">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label fx:id="titleLabel" text="Classement final" styleClass="title"/>

    <TableView fx:id="rankingTable" prefWidth="480" prefHeight="320">
        <columns>
            <TableColumn fx:id="rankColumn" text="#" prefWidth="80"/>
            <TableColumn fx:id="usernameColumn" text="Joueur" prefWidth="240"/>
            <TableColumn fx:id="scoreColumn" text="Score" prefWidth="140"/>
        </columns>
    </TableView>

    <Button text="Retour au lobby" onAction="#onBackToLobbyClicked" styleClass="primary-btn"/>
</VBox>
