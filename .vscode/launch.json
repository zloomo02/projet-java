{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Server: ServerMain",
      "request": "launch",
      "mainClass": "server.ServerMain",
      "projectName": "quiz-server",
      "cwd": "${workspaceFolder}/server"
    },
    {
      "type": "java",
      "name": "Client UI: SwingQuizApp",
      "request": "launch",
      "mainClass": "ui.SwingQuizApp",
      "projectName": "quiz-client",
      "cwd": "${workspaceFolder}/client"
    },
    {
      "type": "java",
      "name": "Client Console: ClientMain",
      "request": "launch",
      "mainClass": "client.ClientMain",
      "projectName": "quiz-client",
      "cwd": "${workspaceFolder}/client"
    }
  ],
  "compounds": [
    {
      "name": "Run Server + Console Client",
      "configurations": [
        "Server: ServerMain",
        "Client Console: ClientMain"
      ]
    },
    {
      "name": "Run Server + Swing Client",
      "configurations": [
        "Server: ServerMain",
        "Client UI: SwingQuizApp"
      ]
    }
  ]
}
